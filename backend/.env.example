# 7KC backend env — copy to .env and edit.

APP_ENV=development
APP_DEBUG=true

# Driver: mysql | sqlite
DB_DRIVER=sqlite

# MySQL (used when DB_DRIVER=mysql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sevenkc
DB_USER=root
DB_PASS=

# SQLite (used when DB_DRIVER=sqlite) — path relative to backend/
DB_SQLITE_PATH=var/sevenkc.sqlite

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_HOURS=168

# CORS
CORS_ALLOW_ORIGIN=http://localhost:5173
