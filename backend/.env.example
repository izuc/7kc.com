# 7KC backend env — copy to .env and edit.

APP_ENV=development
APP_DEBUG=true

# Driver: mysql | sqlite
DB_DRIVER=sqlite

# MySQL (used when DB_DRIVER=mysql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sevenkc
DB_USER=root
DB_PASS=

# SQLite (used when DB_DRIVER=sqlite) — path relative to backend/
DB_SQLITE_PATH=var/sevenkc.sqlite

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_HOURS=168

# CORS
CORS_ALLOW_ORIGIN=http://localhost:5173

# Optional AI photo scanning for "Scan a list" (vision LLM).
# Point at ANY OpenAI-compatible endpoint and the backend forwards the photo to it.
# Leave AI_SCAN_ENDPOINT or AI_SCAN_MODEL blank to keep the feature OFF (falls back to
# on-device OCR). The key, when needed, stays server-side.
#   LM Studio (local):  AI_SCAN_ENDPOINT=http://localhost:1234/v1   AI_SCAN_MODEL=<loaded-vision-model>
#   Ollama (local):     AI_SCAN_ENDPOINT=http://localhost:11434/v1  AI_SCAN_MODEL=llava        (no key)
#   OpenAI:             AI_SCAN_ENDPOINT=https://api.openai.com/v1   AI_SCAN_MODEL=gpt-4o-mini   AI_SCAN_API_KEY=sk-...
AI_SCAN_ENDPOINT=
AI_SCAN_MODEL=
AI_SCAN_API_KEY=
# Fridge/pantry scan tiling: grid per axis (1 = one call on the whole photo; 2 = 2x2 = 4 calls;
# up to 4 = 4x4 = 16 calls). Higher tiles = better recall on packed shelves but proportionally
# more (and slower) model calls per photo. Default 1.
AI_SCAN_TILES=1
